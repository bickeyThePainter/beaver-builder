{
  "name": "Happy Path — Full Pipeline Completion",
  "description": "A task goes through all 7 stages without any reverts or rejections, ending in Completed.",
  "steps": [
    {
      "step": 1,
      "description": "User sends a message to the Planner",
      "op": {
        "type": "UserMessage",
        "payload": {
          "task_id": "task-hp-001",
          "content": "Build a REST API for managing blog posts with CRUD, auth, and pagination"
        }
      },
      "expected_events": [
        {
          "type": "AgentOutput",
          "payload": {
            "pipeline_id": null,
            "stage": "planner",
            "delta": "(LLM response — design questions)",
            "is_final": true
          }
        }
      ],
      "state_after": {
        "notes": "No pipeline yet — still in Planner Chat brainstorm mode"
      }
    },
    {
      "step": 2,
      "description": "User sends follow-up confirming the plan",
      "op": {
        "type": "UserMessage",
        "payload": {
          "task_id": "task-hp-001",
          "content": "Looks good, let's go with that design. Deploy it."
        }
      },
      "expected_events": [
        {
          "type": "AgentOutput",
          "payload": {
            "pipeline_id": null,
            "stage": "planner",
            "delta": "(LLM response — spec summary)",
            "is_final": true
          }
        }
      ],
      "state_after": {
        "notes": "Spec card generated in Planner Chat UI"
      }
    },
    {
      "step": 3,
      "description": "User clicks Deploy Pipeline — StartPipeline op sent",
      "op": {
        "type": "StartPipeline",
        "payload": {
          "task_id": "task-hp-001",
          "workspace_id": "ws-001"
        }
      },
      "expected_events": [
        {
          "type": "PipelineCreated",
          "payload": {
            "pipeline_id": "pipe-hp-001",
            "task_id": "task-hp-001",
            "stage": "planner"
          }
        },
        {
          "type": "StageTransition",
          "payload": {
            "pipeline_id": "pipe-hp-001",
            "from": "created",
            "to": "planner",
            "timestamp": "2026-04-05T10:00:00Z"
          }
        }
      ],
      "state_after": {
        "pipeline_stage": "planner",
        "review_iterations": 0
      }
    },
    {
      "step": 4,
      "description": "Advance: Planner → InitAgent",
      "op": {
        "type": "AdvanceStage",
        "payload": {
          "pipeline_id": "pipe-hp-001"
        }
      },
      "expected_events": [
        {
          "type": "StageTransition",
          "payload": {
            "pipeline_id": "pipe-hp-001",
            "from": "planner",
            "to": "init_agent",
            "timestamp": "2026-04-05T10:01:00Z"
          }
        }
      ],
      "state_after": {
        "pipeline_stage": "init_agent",
        "review_iterations": 0
      }
    },
    {
      "step": 5,
      "description": "Advance: InitAgent → Coder",
      "op": {
        "type": "AdvanceStage",
        "payload": {
          "pipeline_id": "pipe-hp-001"
        }
      },
      "expected_events": [
        {
          "type": "StageTransition",
          "payload": {
            "pipeline_id": "pipe-hp-001",
            "from": "init_agent",
            "to": "coder",
            "timestamp": "2026-04-05T10:02:00Z"
          }
        }
      ],
      "state_after": {
        "pipeline_stage": "coder",
        "review_iterations": 0
      }
    },
    {
      "step": 6,
      "description": "Advance: Coder → Reviewer",
      "op": {
        "type": "AdvanceStage",
        "payload": {
          "pipeline_id": "pipe-hp-001"
        }
      },
      "expected_events": [
        {
          "type": "StageTransition",
          "payload": {
            "pipeline_id": "pipe-hp-001",
            "from": "coder",
            "to": "reviewer",
            "timestamp": "2026-04-05T10:03:00Z"
          }
        }
      ],
      "state_after": {
        "pipeline_stage": "reviewer",
        "review_iterations": 0
      }
    },
    {
      "step": 7,
      "description": "Advance: Reviewer → HumanReview",
      "op": {
        "type": "AdvanceStage",
        "payload": {
          "pipeline_id": "pipe-hp-001"
        }
      },
      "expected_events": [
        {
          "type": "StageTransition",
          "payload": {
            "pipeline_id": "pipe-hp-001",
            "from": "reviewer",
            "to": "human_review",
            "timestamp": "2026-04-05T10:04:00Z"
          }
        },
        {
          "type": "ApprovalRequired",
          "payload": {
            "pipeline_id": "pipe-hp-001",
            "task_id": "task-hp-001",
            "summary": "All stages complete. Ready for human review."
          }
        }
      ],
      "state_after": {
        "pipeline_stage": "human_review",
        "review_iterations": 0
      }
    },
    {
      "step": 8,
      "description": "Human approves the review",
      "op": {
        "type": "ApproveHumanReview",
        "payload": {
          "pipeline_id": "pipe-hp-001"
        }
      },
      "expected_events": [
        {
          "type": "StageTransition",
          "payload": {
            "pipeline_id": "pipe-hp-001",
            "from": "human_review",
            "to": "deploy",
            "timestamp": "2026-04-05T10:05:00Z"
          }
        }
      ],
      "state_after": {
        "pipeline_stage": "deploy",
        "review_iterations": 0
      }
    },
    {
      "step": 9,
      "description": "Advance: Deploy → Push",
      "op": {
        "type": "AdvanceStage",
        "payload": {
          "pipeline_id": "pipe-hp-001"
        }
      },
      "expected_events": [
        {
          "type": "DeployStatus",
          "payload": {
            "pipeline_id": "pipe-hp-001",
            "status": "success",
            "url": "https://staging.example.com/api/v1"
          }
        },
        {
          "type": "StageTransition",
          "payload": {
            "pipeline_id": "pipe-hp-001",
            "from": "deploy",
            "to": "push",
            "timestamp": "2026-04-05T10:06:00Z"
          }
        }
      ],
      "state_after": {
        "pipeline_stage": "push",
        "review_iterations": 0
      }
    },
    {
      "step": 10,
      "description": "Advance: Push → Completed",
      "op": {
        "type": "AdvanceStage",
        "payload": {
          "pipeline_id": "pipe-hp-001"
        }
      },
      "expected_events": [
        {
          "type": "PushComplete",
          "payload": {
            "pipeline_id": "pipe-hp-001",
            "remote": "origin",
            "sha": "f4e3d2c1b0a9f4e3d2c1b0a9f4e3d2c1b0a9f4e3"
          }
        },
        {
          "type": "StageTransition",
          "payload": {
            "pipeline_id": "pipe-hp-001",
            "from": "push",
            "to": "completed",
            "timestamp": "2026-04-05T10:07:00Z"
          }
        }
      ],
      "state_after": {
        "pipeline_stage": "completed",
        "review_iterations": 0
      }
    }
  ]
}
