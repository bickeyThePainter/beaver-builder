    {
      "type": "Push",
      "payload": {
        "pipeline_id": "01JQPIPE000000000000001",
        "remote": "origin",
        "branch": "feat/todo-api"
      }
    },
    {
      "type": "InterruptPipeline",
      "payload": {
        "pipeline_id": "01JQPIPE000000000000001"
      }
    }
  ]
